@model IEnumerable<MovieLibrary.Models.ViewModels.Actors.ActorViewModel>

@{
    ViewData["Title"] = "Actors";
}

<h2 class="mb-4">Actors</h2>

<a asp-action="Create" class="btn btn-primary mb-3">
    Create New Actor
</a>

<table class="table table-striped table-bordered table-light">
    <thead class="table-dark">
        <tr>
            <th>Full Name</th>
            <th>Birth Date</th>
            <th>Movies</th>
            <th style="width: 200px;"></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var actor in Model)
        {
            <tr>
                <td>@actor.FullName</td>
                <td>@actor.BirthDate?.ToString("yyyy-MM-dd")</td>
                <td>@actor.MoviesCount</td>
                <td>
                    <a asp-action="Details" asp-route-id="@actor.Id" class="btn btn-info btn-sm">Details</a>
                    <a asp-action="Edit" asp-route-id="@actor.Id" class="btn btn-warning btn-sm">Edit</a>
                    <a asp-action="Delete" asp-route-id="@actor.Id" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
