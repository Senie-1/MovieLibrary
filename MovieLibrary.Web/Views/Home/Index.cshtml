@model IEnumerable<MovieLibrary.Models.Domain.Entities.Movie>

@{
    ViewData["Title"] = "Home";
}

<div class="mb-5 text-center">
    <h1 class="display-4 fw-bold">Welcome to MovieLibrary</h1>
    <p class="lead text-muted">Discover, rate, and track your favorite movies</p>
</div>

<h3 class="mb-4">Top Rated Movies</h3>

<div class="row row-cols-1 row-cols-md-4 g-4">
    @foreach (var movie in Model)
    {
        <div class="col">
            <div class="card h-100 shadow-sm">
                <img src="@movie.ImageUrl"
                     class="card-img-top"
                     style="height:350px; object-fit:cover;"
                     alt="@movie.Title" />

                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">@movie.Title</h5>
                    <p class="text-muted mb-2">⭐ @movie.Rating</p>

                    <a asp-controller="Movies"
                       asp-action="Details"
                       asp-route-id="@movie.Id"
                       class="btn btn-outline-dark mt-auto">
                        View Details
                    </a>
                </div>
            </div>
        </div>
    }
</div>

