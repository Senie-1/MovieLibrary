@model IEnumerable<MovieLibrary.Models.ViewModels.Movies.MovieViewModel>

<div class="text-center mb-5">
    <h1 class="display-4 text-warning fw-bold">Welcome to MovieLibrary</h1>
    <p class="lead text-light">
        Discover the highest rated movies in our collection.
    </p>
</div>

<div class="row">
    @foreach (var movie in Model)
    {
        <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
            <div class="card bg-dark text-light h-100 shadow">

                <img src="@movie.ImageUrl" class="card-img-top" style="height:350px; object-fit:cover;" />

                <div class="card-body">
                    <h5 class="card-title text-warning">@movie.Title</h5>

                    <p class="mb-1">
                        <strong>Genre:</strong> @movie.Genres
                    </p>

                    <p class="mb-1">
                        <strong>Year:</strong> @movie.ReleaseYear
                    </p>

                    <p class="text-warning">
                        ⭐ @movie.Rating
                    </p>

                    <a asp-controller="Movies"
                       asp-action="Details"
                       asp-route-id="@movie.Id"
                       class="btn btn-outline-warning btn-sm w-100">
                        View Details
                    </a>
                </div>
            </div>
        </div>
    }
</div>
