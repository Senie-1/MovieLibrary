@model MovieLibrary.Models.ViewModels.Movies.MovieCreateOrEditViewModel
<h2>Add Movie</h2>

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label asp-for="Title"></label>
        <input asp-for="Title" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Description"></label>
        <textarea asp-for="Description" class="form-control"></textarea>
    </div>
    <div class="mb-3">
        <label>Genres</label>
        <select asp-for="SelectedGenreIds"
                asp-items="ViewBag.Genres"
                multiple
                class="form-control">
        </select>
    </div>

    <div class="mb-3">
        <label>Actors</label>
        <select asp-for="SelectedActorIds"
                asp-items="ViewBag.Actors"
                multiple
                class="form-control">
        </select>
    </div>

    <div class="mb-3">
        <label asp-for="ReleaseYear"></label>
        <input asp-for="ReleaseYear" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="PosterUrl"></label>
        <input asp-for="PosterUrl" class="form-control" />
    </div>

    <button class="btn btn-success">Save</button>
</form>

