@model MovieLibrary.Models.ViewModels.Movies.MovieViewModel

@{
    ViewData["Title"] = Model.Title;
}

<div class="row mt-4">
    <div class="col-md-4">
        <img src="@Model.ImageUrl"
             class="img-fluid rounded shadow" />
    </div>

    <div class="col-md-8">
        <h1>@Model.Title</h1>

        <p class="mt-3">
            <strong>Rating:</strong> ⭐ @Model.Rating
        </p>

        <p class="mt-3">
            @Model.Description
        </p>

        <a asp-action="Index"
           class="btn btn-outline-secondary mt-3">
            ← Back to Movies
        </a>
    </div>
</div>

