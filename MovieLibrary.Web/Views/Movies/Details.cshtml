@model MovieLibrary.Models.ViewModels.Movies.MovieViewModel

<div class="container mt-4">

    <!-- Movie Title -->
    <h1 class="text-warning mb-4">@Model.Title</h1>

    <div class="row">

        <!-- Movie Poster -->
        <div class="col-lg-4 mb-4">
            <img src="@Model.ImageUrl"
                 class="img-fluid rounded shadow-lg w-100"
                 alt="@Model.Title">
        </div>

        <!-- Movie Info -->
        <div class="col-lg-8">

            <div class="card bg-dark text-light border-secondary shadow">
                <div class="card-body">

                    <h4 class="text-warning mb-3">Movie Info</h4>

                    <p><strong>Genre:</strong> @Model.Genres</p>
                    <p><strong>Release Year:</strong> @Model.ReleaseYear</p>
                    <p><strong>Actors:</strong> @Model.Actors</p>
                    <p><strong>Rating:</strong> ⭐ @Model.Rating / 10</p>

                    <hr />

                    <h5 class="text-warning">Description</h5>
                    <p class="text-light">@Model.Description</p>

                </div>
            </div>

        </div>
    </div>

    <!-- Back Button -->
    <div class="mt-4">
        <a asp-controller="Movies"
           asp-action="Index"
           class="btn btn-outline-warning">
            ← Back to Movies
        </a>
    </div>

</div>