@model MovieLibrary.Models.ViewModels.Movies.MovieViewModel

<div class="container mt-5">

    <div class="row align-items-start">

        <!-- Poster -->
        <div class="col-md-4 text-center">

            <img src="@Model.ImageUrl"
                 class="img-fluid rounded shadow-lg movie-poster"
                 alt="@Model.Title">

            <div class="mt-3">
                <span class="badge bg-warning text-dark fs-6 p-2">
                    ⭐ @Model.Rating
                </span>

                <span class="badge bg-secondary fs-6 p-2">
                    @Model.ReleaseYear
                </span>
            </div>

        </div>


        <!-- Movie Information -->
        <div class="col-md-8">

            <h1 class="text-warning fw-bold">@Model.Title</h1>

            <hr class="border-warning">

            <div class="mb-3">
                <strong class="text-warning">Genre</strong><br />
                <span class="text-light">@Model.Genres</span>
            </div>

            <div class="mb-3">
                <strong class="text-warning">Actors</strong><br />
                <span class="text-light">@Model.Actors</span>
            </div>

            <div class="mt-4">
                <h4 class="text-warning">Synopsis</h4>

                <div class="bg-dark border rounded p-3">
                    @Model.Description
                </div>
            </div>

            <div class="mt-4">

                <a asp-controller="Wishlist"
                   asp-action="Add"
                   asp-route-movieId="@Model.Id"
                   class="btn btn-outline-danger me-2">
                    ❤️ Add to Wishlist
                </a>

                <a asp-controller="Movies"
                   asp-action="Index"
                   class="btn btn-outline-warning">
                    ← Back to Movies
                </a>

            </div>

        </div>

    </div>

</div>