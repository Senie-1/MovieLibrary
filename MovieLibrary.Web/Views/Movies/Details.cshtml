@model MovieLibrary.Models.ViewModels.Movies.MovieViewModel

<div class="container mt-5">
    <div class="row align-items-start">

        <!-- Poster -->
        <div class="col-md-4 text-center">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="~/@Model.ImageUrl"
                     class="img-fluid rounded"
                     style="max-height:400px; object-fit:cover;" />
            }

            <div class="mt-3">
                <span class="badge bg-warning text-dark fs-6 p-2">
                    ⭐ @Model.Rating
                </span>

                <span class="badge bg-info text-dark fs-6 p-2">
                    @string.Join(", ", Model.Genres)
                </span>

                <span class="badge bg-secondary fs-6 p-2">
                    @Model.ReleaseYear
                </span>
            </div>
        </div>

        <!-- Movie Information -->
        <div class="col-md-8">

            <h1 class="text-warning fw-bold">@Model.Title</h1>
            <hr class="border-warning">

            <div class="mb-3">
                <strong class="text-warning">Genre</strong><br />
                <span class="text-light">
                    @string.Join(", ", Model.Genres)
                </span>
            </div>

            <div class="mb-3">
                <strong class="text-warning">Actors</strong><br />
                <span class="text-light">
                    @string.Join(", ", Model.Actors)
                </span>
            </div>

            <div class="mt-4">
                <h4 class="text-warning">Synopsis</h4>
                <div class="bg-dark border rounded p-3">
                    @Model.Description
                </div>
            </div>

            <div class="mt-4">
                <form asp-controller="Wishlist" asp-action="Add" method="post">
                    <input type="hidden" name="movieId" value="@Model.Id" />
                    <input type="hidden" name="status" value="WantToWatch" />
                    @Html.AntiForgeryToken()

                    <button type="submit" class="btn btn-outline-danger">
                        ❤️ Add to Wishlist
                    </button>
                </form>

                <a asp-controller="Movies"
                   asp-action="Index"
                   class="btn btn-outline-warning">
                    ← Back to Movies
                </a>
            </div>

        </div>
    </div>
</div>